{
  "name": "pin-keeper",
  "description": "Automatically manage and restore pinned tabs with flexible URL matching rules",
  "license": "MIT",
  "private": true,
  "version": "1.8.2",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "test": "vitest"
  },
  "dependencies": {
    "@dnd-kit/abstract": "0.3.2",
    "@dnd-kit/collision": "0.3.2",
    "@dnd-kit/dom": "0.3.2",
    "@dnd-kit/react": "0.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@tailwindcss/vite": "4.2.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "nanoid": "5.1.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/chrome": "0.1.40",
    "@types/node": "24.9.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/auto-icons": "1.1.1",
    "@wxt-dev/module-react": "1.2.2",
    "lefthook": "2.1.6",
    "npm-run-all2": "8.0.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wxt": "0.20.20"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dtrace-provider",
      "esbuild",
      "lefthook",
      "spawn-sync"
    ],
    "overrides": {
      "vite": "$vite"
    }
  }
}
